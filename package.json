{
  "name": "@cookshack/eslint-config",
  "version": "6.0.2",
  "description": "ESLint config for Cookshack projects",
  "homepage": "https://git.sr.ht/~mattmundell/eslint-config",
  "type": "module",
  "scripts": {
    "build-linter": "node scripts/build-linter.mjs",
    "check": "npx eslint --no-warn-ignored -f ./formatter.js -c ./index.js *.js test/rules/*.js plugins/*.js",
    "test": "mocha test/**/*.js",
    "prepare": "husky && rollup -c 1>&2 && node scripts/build-linter.mjs",
    "postinstall": "patch-package"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs",
    "./eslint-linter-browserify.mjs": "./dist/eslint-linter-browserify.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://git.sr.ht/~mattmundell/eslint-config"
  },
  "author": "Matt Mundell",
  "license": "CC0-1.0",
  "dependencies": {
    "eslint": "^10.4.0",
    "eslint-linter-browserify": "^10.4.0",
    "globals": "^15.10.0",
    "patch-package": "^8.0.1"
  },
  "devDependencies": {
    "diff": "^8.0.4",
    "husky": "^9.1.7",
    "mocha": "^11.7.5",
    "rollup": "^4.27.2"
  }
}
