{
  "name": "@cookshack/eslint-config",
  "version": "2.0.4",
  "description": "ESLint config for Cookshack projects",
  "homepage": "https://git.sr.ht/~mattmundell/eslint-config",
  "type": "module",
  "scripts": {
    "check": "npx eslint --no-warn-ignored -f ./formatter.js -c ./index.js *.js test/rules/*.js",
    "test": "mocha test/**/*.js",
    "prepare": "husky && rollup -c"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://git.sr.ht/~mattmundell/eslint-config"
  },
  "author": "Matt Mundell",
  "license": "CC0-1.0",
  "dependencies": {
    "eslint": "9.24",
    "globals": "^15.10.0"
  },
  "devDependencies": {
    "diff": "^8.0.4",
    "husky": "^9.1.7",
    "mocha": "^11.7.5",
    "rollup": "^4.27.2"
  }
}
